# Coding Tool Bake-off — environment configuration.
# Copy to .env (setup.sh does this automatically) and edit as needed.

# ── Auth (optional — only set if /login flow doesn't work) ──────────────
# ANTHROPIC_API_KEY=sk-ant-...
# COPILOT_GITHUB_TOKEN=github_pat_...           # fine-grained, with Copilot scope

# ── Pricing ─────────────────────────────────────────────────────────────
# Bob: USD per Bobcoin. Default 0.50 (1 coin = 50¢).
BOB_USD_PER_BOBCOIN=0.50

# Copilot Free / Pro CLI only exposes Haiku & GPT-4.1, but GitHub bills
# Copilot per-token at underlying-model rates after June 1, 2026. This
# setting prices the run AS IF it ran on the named model — for a fair
# competitive comparison with Claude Code (which defaults to Opus 4.7).
# Options: claude-haiku-4.5, claude-sonnet-4.5, claude-sonnet-4.6,
# claude-opus-4.7, gpt-5.2, gpt-5.4, gpt-5.5, gemini-2.5-pro, etc.
# (Full list + rates: src/pricing/rates.yaml)
COPILOT_DISPLAY_AS_MODEL=claude-sonnet-4.6

# ── Runtime ─────────────────────────────────────────────────────────────
BAKEOFF_DEFAULT_SCENARIO=01-sqli-flask
BAKEOFF_TIMEOUT_SECONDS=600
BAKEOFF_PORT=8765

# ── Tool modes (optional) ───────────────────────────────────────────────
# Bob chat-mode. Options: advanced, code, plan, ask, code-navigator.
BOB_CHAT_MODE=advanced

# Override the model each tool runs with (leave blank for OOB defaults).
# BOB_MODEL=premium
# CLAUDE_MODEL=sonnet
# COPILOT_MODEL=claude-sonnet-4.5
